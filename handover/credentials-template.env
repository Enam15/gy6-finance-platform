# =============================================================================
# GY6 Finance — credentials checklist  (FILL IN, THEN STORE IN A PASSWORD MANAGER)
# =============================================================================
#
# This is a blank checklist of every secret the system uses. It ships with NO
# real values on purpose.
#
#   • Fill it in, then keep the completed copy ONLY in a password manager
#     (1Password / Bitwarden / etc.). Do NOT commit it, email it, or paste it
#     into chat.
#   • For the LIVE site, these same values go in Vercel → Settings →
#     Environment Variables (Production). The SEED_* ones are only used on a
#     laptop when creating login users.
#   • See 2-accounts-and-credentials.md and 4-run-and-deploy.md for context.
#
# -----------------------------------------------------------------------------
# DATABASE  (from GY6's own PostgreSQL / Neon project — see 3-database-handover.md)
# -----------------------------------------------------------------------------

# Pooled connection (host contains "-pooler"). Used by the running app.
DATABASE_URL="postgresql://USER:PASSWORD@POOLED-HOST/DATABASE?sslmode=require"

# Direct connection (host WITHOUT "-pooler"). Used for structure changes.
# For a plain local database, set this to the same value as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT-HOST/DATABASE?sslmode=require"

# -----------------------------------------------------------------------------
# LOGIN SESSION KEY
# -----------------------------------------------------------------------------

# Generate a FRESH value (do not reuse the old one):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="GENERATE-A-NEW-32-BYTE-BASE64-VALUE"

# -----------------------------------------------------------------------------
# LOGIN USERS  (used only on a laptop when running `npm run db:seed`)
# Use strong passwords — 12+ characters. The seed refuses weak ones in production.
# -----------------------------------------------------------------------------

SEED_TASHFEEN_EMAIL="tashfeen@gy6.com"
SEED_TASHFEEN_PASSWORD="SET-A-STRONG-PASSWORD"
SEED_ITMAM_EMAIL="itmam@gy6.com"
SEED_ITMAM_PASSWORD="SET-A-STRONG-PASSWORD"

# Set to 1 only when you deliberately want to reset existing users' passwords.
SEED_RESET_PASSWORDS="0"

# =============================================================================
# ACCOUNTS TO OWN (not app settings — track who holds each; keep updated)
# =============================================================================
# GitHub repo   : github.com/Enam15/gy6-finance-platform  → owner: ____________
# Vercel project: (project name)                          → owner: ____________
# Database host : (Neon / other)                          → owner: ____________
# Custom domain : (if any)                                → owner: ____________
