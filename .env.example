# ---------------------------------------------------------------------------
# GY6 Finance Management System - environment variables
# Copy this file to ".env" and fill in real values. Never commit ".env".
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by the application and Prisma Client.
# Use a local PostgreSQL install or a cloud provider such as Neon (neon.tech).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/gy6_finance?schema=public"

# Direct (non-pooled) connection. With a pooled provider like Neon, point this
# at the direct endpoint so Prisma Migrate can run DDL. With a plain local
# database, set it to the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/gy6_finance?schema=public"
