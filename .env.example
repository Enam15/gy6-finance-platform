# ---------------------------------------------------------------------------
# GY6 Finance Management System - environment variables
# Copy this file to ".env" and fill in real values. Never commit ".env".
# In production, set the same keys in the Vercel project settings.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# Runtime connection used by the application and Prisma Client. In production
# this is the POOLED connection string (e.g. Neon's "-pooler" host) so
# serverless functions don't exhaust direct connections.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/gy6_finance?schema=public"

# Direct (non-pooled) connection, used ONLY by the Prisma CLI for migrations.
# Poolers (PgBouncer / Neon pooler) break the advisory locks DDL relies on, so
# migrations must use the direct host. With a plain local database, set it to
# the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/gy6_finance?schema=public"

# --- Auth -----------------------------------------------------------------
# Signs the Auth.js session JWT. Generate a fresh one per environment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="generate-a-32-byte-base64-secret"

# --- Seed credentials -----------------------------------------------------
# Used by `npm run db:seed` to create the two app users. Use STRONG values in
# production (>= 12 characters; the seed refuses weak ones when
# NODE_ENV=production).
SEED_TASHFEEN_EMAIL="tashfeen@gy6.local"
SEED_TASHFEEN_PASSWORD="change-me-to-a-strong-password"
SEED_ITMAM_EMAIL="itmam@gy6.local"
SEED_ITMAM_PASSWORD="change-me-to-a-strong-password"

# Set to 1 to overwrite an existing user's password on re-seed. Default 0
# leaves existing passwords untouched (only name/active are refreshed).
SEED_RESET_PASSWORDS="0"
