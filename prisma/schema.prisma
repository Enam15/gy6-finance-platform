// GY6 Finance Management System - Prisma schema
// Docs: https://pris.ly/d/prisma-schema
//
// Prisma 7: the datasource block carries no `url`. The connection string is
// supplied to the CLI via prisma.config.ts and to the runtime client via a
// driver adapter (see lib/prisma.ts).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Stable identifier for each account category.
enum AccountCategoryKey {
  BUSINESS
  FOUNDER
  CLIENT
  EMPLOYEE
  SUBSCRIPTION
  SYSTEM
}

/// Identifies the hidden internal accounts that give double-entry postings a
/// counter-account in the movement-based ledger.
enum SystemAccountKey {
  REVENUE
  EXPENSE
  ADJUSTMENTS
  OPENING_BALANCES
  TRANSACTION_FEES
}

/// Which side of an account a debit posting falls on. A debit increases a
/// debit-normal account and decreases a credit-normal one; a credit does the
/// reverse. This is the minimum double-entry needs to keep balances correct.
enum NormalBalance {
  DEBIT
  CREDIT
}

/// Lifecycle of an income entry, expense entry, or transfer.
enum EntryState {
  DRAFT
  CONFIRMED
  REVERSED
}

/// What an income/expense transaction category applies to.
enum CategoryKind {
  INCOME
  EXPENSE
}

/// The recurrence unit for a renewal template (e.g. every 1 MONTH).
enum RecurrenceUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

/// How a transaction fee was charged. The free-text label on the entry
/// captures the specific bank, online wallet, or Upwork account name.
enum FeeMethod {
  BANK
  UPWORK
  ONLINE_WALLET
}

/// The nature of a ledger posting.
enum StatementEntryType {
  INCOME
  EXPENSE
  PAYMENT
  TRANSFER
  ADJUSTMENT
  REVERSAL
  OPENING_BALANCE
  DISTRIBUTION
}

/// The kind of operational record a statement entry was posted from.
enum StatementSourceType {
  INCOME_ENTRY
  EXPENSE_ENTRY
  PAYMENT
  TRANSFER
  BALANCE_ADJUSTMENT
  DISTRIBUTION
}

/// The kind of change recorded in an audit log entry.
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  CONFIRM
  REVERSE
  TRANSFER
  ADJUST
  RENEW
  EXPORT
}

// ---------------------------------------------------------------------------
// Reference models
// ---------------------------------------------------------------------------

/// Account category. Drives balance visibility in the UI - Employee and
/// Subscription balances are hidden; Business, Founder and Client are shown.
/// The SYSTEM category holds hidden internal accounts and is never user-facing.
model AccountCategory {
  id             String             @id @default(uuid(7))
  key            AccountCategoryKey @unique
  name           String
  balanceVisible Boolean            @map("balance_visible")
  isSystem       Boolean            @default(false) @map("is_system")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  accounts Account[]

  @@map("account_categories")
}

/// A money-holding entity in the ledger: a business bank account, a founder, a
/// client, an employee, a subscription, or a hidden system account. Every
/// transaction moves value between two accounts. `balance` is materialised in
/// minor units (integer, never float) and is mutated only by ledger events.
model Account {
  id            String            @id @default(uuid(7))
  categoryId    String            @map("category_id")
  name          String
  systemKey     SystemAccountKey? @unique @map("system_key")
  normalBalance NormalBalance     @map("normal_balance")
  description   String?
  balance       BigInt            @default(0)
  allowNegative Boolean           @default(false) @map("allow_negative")
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  category AccountCategory @relation(fields: [categoryId], references: [id])

  debitEntries       StatementEntry[]    @relation("DebitAccount")
  creditEntries      StatementEntry[]    @relation("CreditAccount")
  incomeEntries      IncomeEntry[]
  expenseEntries     ExpenseEntry[]
  payments           Payment[]
  transfersFrom      Transfer[]          @relation("TransferFrom")
  transfersTo        Transfer[]          @relation("TransferTo")
  balanceAdjustments BalanceAdjustment[]
  partner            Partner?
  distributions      Distribution[]
  renewalTemplates   RenewalTemplate[]

  @@index([categoryId])
  @@map("accounts")
}

/// Append-only audit trail. Every state-changing operation writes one row.
/// Rows are never updated or deleted - corrections are new entries.
model AuditLog {
  id         String      @id @default(uuid(7))
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id")
  summary    String
  before     Json?
  after      Json?
  metadata   Json?
  actorId    String?     @map("actor_id")
  actorLabel String?     @map("actor_label")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// User-defined label classifying an income or expense transaction. Distinct
/// from account categories, which classify accounts rather than transactions.
model TransactionCategory {
  id        String       @id @default(uuid(7))
  name      String
  kind      CategoryKind
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  incomeEntries    IncomeEntry[]
  expenseEntries   ExpenseEntry[]
  renewalTemplates RenewalTemplate[]

  @@unique([name, kind])
  @@map("transaction_categories")
}

// ---------------------------------------------------------------------------
// Ledger
// ---------------------------------------------------------------------------

/// The immutable double-entry ledger. Every confirmed transaction posts one or
/// more balanced rows here. Rows are append-only - never updated or deleted;
/// corrections are new REVERSAL rows. A database trigger enforces this in
/// addition to the repository layer (see the migration).
model StatementEntry {
  id                 String              @id @default(uuid(7))
  transactionGroupId String              @map("transaction_group_id")
  entryType          StatementEntryType  @map("entry_type")
  debitAccountId     String              @map("debit_account_id")
  creditAccountId    String              @map("credit_account_id")
  amount             BigInt
  description        String
  effectiveDate      DateTime            @db.Date @map("effective_date")
  sourceType         StatementSourceType @map("source_type")
  sourceId           String              @map("source_id")
  reversesEntryId    String?             @unique @map("reverses_entry_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  createdBy          String?             @map("created_by")

  debitAccount  Account         @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount Account         @relation("CreditAccount", fields: [creditAccountId], references: [id])
  reverses      StatementEntry? @relation("Reversal", fields: [reversesEntryId], references: [id])
  reversedBy    StatementEntry? @relation("Reversal")

  @@index([transactionGroupId])
  @@index([sourceType, sourceId])
  @@index([debitAccountId])
  @@index([creditAccountId])
  @@index([effectiveDate])
  @@map("statement_entries")
}

// ---------------------------------------------------------------------------
// Operational transaction records
// ---------------------------------------------------------------------------

/// Operational income record. The full amount is recognised on the ledger when
/// the entry is CONFIRMED; payments against it are recorded separately.
/// `amountDue` is service-maintained and DB-checked to equal total - paid.
model IncomeEntry {
  id              String     @id @default(uuid(7))
  clientAccountId String     @map("client_account_id")
  categoryId      String     @map("category_id")
  description     String
  totalAmount     BigInt     @map("total_amount")
  amountPaid      BigInt     @default(0) @map("amount_paid")
  amountDue       BigInt     @map("amount_due")
  entryDate       DateTime   @db.Date @map("entry_date")
  paymentDueOn    DateTime   @db.Date @map("payment_due_on")
  state             EntryState @default(DRAFT)
  confirmedAt       DateTime?  @map("confirmed_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  createdBy         String?    @map("created_by")
  renewalTemplateId String?    @map("renewal_template_id")
  feeMethod         FeeMethod? @map("fee_method")
  feeLabel          String?    @map("fee_label")
  feeBps            Int?       @map("fee_bps")
  feeAmount         BigInt?    @map("fee_amount")

  clientAccount   Account             @relation(fields: [clientAccountId], references: [id])
  category        TransactionCategory @relation(fields: [categoryId], references: [id])
  payments        Payment[]
  attachments     Attachment[]
  renewalTemplate RenewalTemplate?    @relation(fields: [renewalTemplateId], references: [id])

  @@index([clientAccountId])
  @@index([categoryId])
  @@index([state])
  @@index([paymentDueOn])
  @@index([renewalTemplateId])
  @@map("income_entries")
}

/// Operational expense record. Mirror of IncomeEntry, for money GY6 owes.
model ExpenseEntry {
  id             String     @id @default(uuid(7))
  payeeAccountId String     @map("payee_account_id")
  categoryId     String     @map("category_id")
  description    String
  totalAmount    BigInt     @map("total_amount")
  amountPaid     BigInt     @default(0) @map("amount_paid")
  amountDue      BigInt     @map("amount_due")
  entryDate      DateTime   @db.Date @map("entry_date")
  paymentDueOn   DateTime   @db.Date @map("payment_due_on")
  state             EntryState @default(DRAFT)
  confirmedAt       DateTime?  @map("confirmed_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  createdBy         String?    @map("created_by")
  renewalTemplateId String?    @map("renewal_template_id")
  feeMethod         FeeMethod? @map("fee_method")
  feeLabel          String?    @map("fee_label")
  feeBps            Int?       @map("fee_bps")
  feeAmount         BigInt?    @map("fee_amount")

  payeeAccount    Account             @relation(fields: [payeeAccountId], references: [id])
  category        TransactionCategory @relation(fields: [categoryId], references: [id])
  payments        Payment[]
  attachments     Attachment[]
  renewalTemplate RenewalTemplate?    @relation(fields: [renewalTemplateId], references: [id])

  @@index([payeeAccountId])
  @@index([categoryId])
  @@index([state])
  @@index([paymentDueOn])
  @@index([renewalTemplateId])
  @@map("expense_entries")
}

/// An instalment payment against a confirmed income or expense entry. Exactly
/// one of incomeEntryId / expenseEntryId is set (enforced by a DB check).
model Payment {
  id                String   @id @default(uuid(7))
  incomeEntryId     String?  @map("income_entry_id")
  expenseEntryId    String?  @map("expense_entry_id")
  businessAccountId String   @map("business_account_id")
  amount            BigInt
  paidOn            DateTime @db.Date @map("paid_on")
  description       String?
  createdAt         DateTime @default(now()) @map("created_at")
  createdBy         String?  @map("created_by")

  incomeEntry     IncomeEntry?  @relation(fields: [incomeEntryId], references: [id])
  expenseEntry    ExpenseEntry? @relation(fields: [expenseEntryId], references: [id])
  businessAccount Account       @relation(fields: [businessAccountId], references: [id])

  @@index([incomeEntryId])
  @@index([expenseEntryId])
  @@index([businessAccountId])
  @@map("payments")
}

/// A transfer of cash between two of GY6's own accounts.
model Transfer {
  id            String     @id @default(uuid(7))
  fromAccountId String     @map("from_account_id")
  toAccountId   String     @map("to_account_id")
  amount        BigInt
  description   String?
  feeMethod     FeeMethod? @map("fee_method")
  feeLabel      String?    @map("fee_label")
  feeBps        Int?       @map("fee_bps")
  feeAmount     BigInt?    @map("fee_amount")
  effectiveDate DateTime   @db.Date @map("effective_date")
  state         EntryState @default(DRAFT)
  confirmedAt   DateTime?  @map("confirmed_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  createdBy     String?    @map("created_by")

  fromAccount Account @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount   Account @relation("TransferTo", fields: [toAccountId], references: [id])

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([effectiveDate])
  @@map("transfers")
}

/// A manual balance correction. Records the before/after balance and posts the
/// difference through the ledger against the Adjustments system account.
model BalanceAdjustment {
  id              String   @id @default(uuid(7))
  accountId       String   @map("account_id")
  previousBalance BigInt   @map("previous_balance")
  newBalance      BigInt   @map("new_balance")
  difference      BigInt
  reason          String
  effectiveDate   DateTime @db.Date @map("effective_date")
  createdAt       DateTime @default(now()) @map("created_at")
  createdBy       String?  @map("created_by")

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@map("balance_adjustments")
}

// ---------------------------------------------------------------------------
// Shared notes
// ---------------------------------------------------------------------------

/// A free-form shared note - a scratchpad both partners can read and write,
/// for reminders and things to keep an eye on. Not financial data, so notes
/// can be edited and deleted (unlike the immutable ledger).
model Note {
  id        String   @id @default(uuid(7))
  body      String
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("notes")
}

// ---------------------------------------------------------------------------
// Recurring renewals
// ---------------------------------------------------------------------------

/// A recurring income or expense template. "Generate due renewals" reads
/// every active template whose nextRunOn has arrived and materialises a new
/// DRAFT entry from it - it never auto-posts. The user reviews and confirms
/// each generated draft. `accountId` is the client account when kind=INCOME
/// or the payee account when kind=EXPENSE; the service validates that the
/// category's kind matches. `paymentTermsDays` becomes the offset from a
/// generated entry's entryDate to its paymentDueOn.
model RenewalTemplate {
  id               String         @id @default(uuid(7))
  kind             CategoryKind
  name             String
  accountId        String         @map("account_id")
  categoryId       String         @map("category_id")
  description      String
  totalAmount      BigInt         @map("total_amount")
  paymentTermsDays Int            @default(0) @map("payment_terms_days")
  intervalCount    Int            @map("interval_count")
  intervalUnit     RecurrenceUnit @map("interval_unit")
  nextRunOn        DateTime       @db.Date @map("next_run_on")
  endOn            DateTime?      @db.Date @map("end_on")
  isActive         Boolean        @default(true) @map("is_active")
  lastGeneratedAt  DateTime?      @map("last_generated_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  createdBy        String?        @map("created_by")

  account        Account             @relation(fields: [accountId], references: [id])
  category       TransactionCategory @relation(fields: [categoryId], references: [id])
  incomeEntries  IncomeEntry[]
  expenseEntries ExpenseEntry[]

  @@index([isActive, nextRunOn])
  @@index([accountId])
  @@index([categoryId])
  @@map("renewal_templates")
}

// ---------------------------------------------------------------------------
// Profit distribution
// ---------------------------------------------------------------------------

/// A profit-distribution partner. Each Partner is bound to one Founder-
/// category Account where their distributions land. Share ratios are
/// time-sliced via PartnerShareSlice.
model Partner {
  id               String              @id @default(uuid(7))
  name             String              @unique
  founderAccountId String              @unique @map("founder_account_id")
  isActive         Boolean             @default(true) @map("is_active")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  founderAccount   Account             @relation(fields: [founderAccountId], references: [id])
  shareSlices      PartnerShareSlice[]
  shares           DistributionShare[]

  @@map("partners")
}

/// Time-sliced share ratio for a partner. The slice active at a given
/// distribution date is the most recent one with effective_from <= date.
/// Ratios are integer numerators; the denominator (sum across active
/// partners) is computed and snapshotted at distribution time.
model PartnerShareSlice {
  id            String   @id @default(uuid(7))
  partnerId     String   @map("partner_id")
  ratio         Int
  effectiveFrom DateTime @db.Date @map("effective_from")
  createdAt     DateTime @default(now()) @map("created_at")

  partner       Partner  @relation(fields: [partnerId], references: [id])

  @@unique([partnerId, effectiveFrom])
  @@map("partner_share_slices")
}

/// A single quarterly profit-distribution event. Multiple distributions per
/// quarter are allowed (top-ups, corrections); each is its own immutable
/// row. Per-partner postings move cash from the Business source account
/// into each partner's Founder account in one ledger transaction.
model Distribution {
  id              String              @id @default(uuid(7))
  quarterStart    DateTime            @db.Date @map("quarter_start")
  netAmount       BigInt              @map("net_amount")
  sourceAccountId String              @map("source_account_id")
  description     String?
  effectiveDate   DateTime            @db.Date @map("effective_date")
  createdAt       DateTime            @default(now()) @map("created_at")
  createdBy       String?             @map("created_by")

  sourceAccount   Account             @relation(fields: [sourceAccountId], references: [id])
  shares          DistributionShare[]

  @@index([quarterStart])
  @@index([sourceAccountId])
  @@map("distributions")
}

/// The per-partner allocation of one distribution. Snapshots both the
/// numerator (ratio) and denominator (ratioDenominator) used at the time,
/// so the historical record stands on its own without re-resolving slices.
model DistributionShare {
  id               String       @id @default(uuid(7))
  distributionId   String       @map("distribution_id")
  partnerId        String       @map("partner_id")
  ratio            Int
  ratioDenominator Int          @map("ratio_denominator")
  amount           BigInt

  distribution     Distribution @relation(fields: [distributionId], references: [id])
  partner          Partner      @relation(fields: [partnerId], references: [id])

  @@index([distributionId])
  @@index([partnerId])
  @@map("distribution_shares")
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

/// Internal application user. Authenticated via Credentials (email + bcrypt
/// password hash). actorId/actorLabel on audit log rows trace back here, so
/// every state-changing operation is attributable to a real person.
/// Named `AppUser` to keep clear of the domain `Account` model.
model AppUser {
  id           String    @id @default(uuid(7))
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("app_users")
}

/// File attachment metadata for an income or expense entry. The file itself
/// lives in object storage under `storageKey`; upload wiring arrives later.
/// Exactly one of incomeEntryId / expenseEntryId is set (DB check enforced).
model Attachment {
  id             String   @id @default(uuid(7))
  incomeEntryId  String?  @map("income_entry_id")
  expenseEntryId String?  @map("expense_entry_id")
  fileName       String   @map("file_name")
  storageKey     String   @map("storage_key")
  contentType    String   @map("content_type")
  sizeBytes      Int      @map("size_bytes")
  uploadedAt     DateTime @default(now()) @map("uploaded_at")
  uploadedBy     String?  @map("uploaded_by")

  incomeEntry  IncomeEntry?  @relation(fields: [incomeEntryId], references: [id])
  expenseEntry ExpenseEntry? @relation(fields: [expenseEntryId], references: [id])

  @@index([incomeEntryId])
  @@index([expenseEntryId])
  @@map("attachments")
}
